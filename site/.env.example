# Frontend env vars consumed at build time by Vite.
# Copy to .env.local (gitignored) and fill in real values.

# Cloudflare Turnstile site key (public — safe to commit if desired).
# Leave blank to disable Turnstile entirely (form will skip the captcha check).
VITE_TURNSTILE_SITE_KEY=

# Override the feedback API endpoint. Defaults to /api/feedback
# (relative — served by the Cloudflare Worker route on this domain).
# VITE_FEEDBACK_API=
